# Create a NEW Supabase project for FFB4 — do not reuse FFB3 keys.
# Dashboard: https://supabase.com/dashboard → New project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_ffb4_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_ffb4_publishable_key_here
SUPABASE_SECRET_KEY=your_ffb4_secret_key_here
