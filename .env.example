# Create a NEW Supabase project for FFB4 — do not reuse FFB3 keys.
# Dashboard: https://supabase.com/dashboard → New project

# API keys: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_ffb4_project_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_ffb4_publishable_key_here
SUPABASE_SECRET_KEY=your_ffb4_secret_key_here

# Database: Connect button → Connection string → URI → Session pooler
# Use postgres.<project-ref> user, pooler host (not db.xxx.supabase.co direct)
# Replace [YOUR-PASSWORD] with real password — no brackets; encode ! as %21
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-region.pooler.supabase.com:5432/postgres
